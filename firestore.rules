rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notices
    // Fields: titleEn, titleOl, contentEn, contentOl, date, isImportant, link
    //
    // Collection: members
    // Fields: nameEn, nameOl, designationEn, designationOl, roleEn, roleOl, photoUrl, order
    //
    // Collection: events
    // Fields: titleEn, titleOl, descriptionEn, descriptionOl, date, images, year, category
    //
    // Collection: achievements
    // Fields: nameEn, nameOl, exam, rank, year, descriptionEn, descriptionOl
    //
    // Collection: gallery
    // Fields: url, category, captionEn, captionOl
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "sandiphembram2021@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Public Read-Only Collections
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if true; // Allow public creation for registration notifications
      allow update, delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles (Private)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Admins can read all users
      allow read: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
